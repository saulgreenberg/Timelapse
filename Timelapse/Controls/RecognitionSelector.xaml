<UserControl x:Class="Timelapse.Controls.RecognitionSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Timelapse.Controls"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             mc:Ignorable="d" 
             DataContext="{Binding RelativeSource={RelativeSource Self}}"
             d:DesignHeight="350" d:DesignWidth="600" Loaded="RecognitionsSelector_OnLoaded">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="250"/>

            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!--Detections-->
            <Grid Grid.Row="2" Grid.Column="0" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!--Detections label-->

                <TextBlock Name="TBDetectionsLabel" 
                       Grid.Row="0" Grid.Column="0" 
                       HorizontalAlignment="Center">
                    <Run Text="Detections" FontWeight="Bold" />
                    <Run Name="TBDetectionsCount" Text="" FontWeight="Normal" />
                </TextBlock>

                <!--Detections slider-->
                <xctk:RangeSlider Grid.Row="1" 
                              Name="SliderDetectionConf" 
                              Margin="0,0,0,5"
                              Minimum="0" Maximum="1" 
                              LowerValue=".2" HigherValue="1" 
                              RangeBackground="Gold" 
                              HigherRangeBackground="Transparent"
                              LowerRangeBackground="Transparent"
                              TickFrequency="0.1" TickPlacement="None"
                              Step="0.1"
                              IsSnapToTickEnabled="False"
                              PreviewMouseLeftButtonDown="SliderDetectionConf_OnPreviewMouseLeftButtonDown"
                              PreviewMouseLeftButtonUp="SliderDetectionConf_OnPreviewMouseLeftButtonUp"
                              LowerValueChanged="SliderDetectionConf_ValueChanged" 
                              HigherValueChanged="SliderDetectionConf_ValueChanged"
            />

                <!--Detections Datagrid-->
                <DataGrid Grid.Row="2" Grid.Column="0" 
                      Name="DataGridDetections" 
                      ItemsSource ="{Binding DetectionCountsCollection}"
                      IsReadOnly ="True"
                      HorizontalGridLinesBrush="LightGray"
                      VerticalGridLinesBrush="LightGray"
                      CanUserSortColumns="True"
                      SelectionChanged="DataGridDetections_OnSelectionChanged"/>
                
                <!-- Rank By Confidence Checkbox-->
                <RadioButton Name="RankByDetectionConfidenceCheckbox" GroupName="RankByRadioButtons" Content="Sort by detection confidence" Grid.Row="3" Grid.Column="0" Margin="0,10,0,0" 
                          VerticalAlignment="Center" HorizontalAlignment="Left" IsChecked="False" 
                          Checked="RankByConfidence_CheckedChanged" Unchecked="RankByConfidence_CheckedChanged"
                          ToolTip="Sorts the results by confidence.&#10;The confidence value used (detection or classification) depends upon the 'Recognized entity' menu selection."/>
            </Grid>

            <!--Classifications-->
            <Grid Grid.Row="2" Grid.Column="1" Margin="10,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!--Classifications label-->

                <TextBlock Name="TBClassificationsLabel" 
                           Grid.Row="0" Grid.Column="0"  
                           HorizontalAlignment="Center" Margin="0,0,0,0" >
                           <Run Text="Classifications " FontWeight="Bold" />
                           <Run Name="TBClassificationsCount" Text="" FontWeight="Normal" />
                </TextBlock>

                <!--Classifications slider -->
                <xctk:RangeSlider Grid.Row="1" Name="SliderClassificationConf"  
                                    Margin="0,0,0,5"
                                    Minimum="0" Maximum="1" 
                                    LowerValue=".75" HigherValue="1" 
                                    RangeBackground="Gold" 
                                    HigherRangeBackground="Transparent"
                                    LowerRangeBackground="Transparent"
                                    TickFrequency="0.1" TickPlacement="None"
                                    Step="0.1"
                                    IsSnapToTickEnabled="False"
                                    PreviewMouseLeftButtonDown="SliderClassificationConf_OnPreviewMouseLeftButtonDown"
                                    PreviewMouseLeftButtonUp="SliderClassificationConf_OnPreviewMouseLeftButtonUp"
                                    PreviewKeyDown="SliderClassificationConf_OnPreviewKeyDown"
                                    LowerValueChanged="SliderClassificationConf_ValueChanged" 
                                    HigherValueChanged="SliderClassificationConf_ValueChanged">
                </xctk:RangeSlider>

                <!--Classifications DataGrid-->
                <DataGrid Grid.Row="2" Grid.Column="0" 
                      Name="DataGridClassifications" 
                      ItemsSource ="{Binding ClassificationCountsCollection}"
                      IsReadOnly ="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      HorizontalGridLinesBrush="LightGray"
                      VerticalGridLinesBrush="LightGray"
                      CanUserSortColumns="True"
                      SelectionChanged="DataGridClassifications_OnSelectionChanged">
                    <!--Hide rows with a count of 0-->
                    <DataGrid.RowStyle>
                        <Style TargetType="{x:Type DataGridRow}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                </DataGrid>

                <!--Empty Classifications -->
                <xctk:DropDownButton Grid.Row="3" Name="DropDownEmptyClassifications" 
                                     DropDownPosition="Bottom"
                                     Margin="0,10,0,0">
                    <xctk:DropDownButton.DropDownContent >
                        <Border  BorderBrush="DarkGray" BorderThickness="1" Padding="3,3,3,3"  >
                            <ScrollViewer Name="EmptyClassificationsScrollViewer"  VerticalScrollBarVisibility="Visible" CanContentScroll="True" Height="250" Width="{Binding ActualWidth, ElementName=DropDownEmptyClassifications}" >
                                    <ItemsControl Name="LBEmptyClassifications" MinWidth ="200" />
                                </ScrollViewer>
                            </Border>
                    </xctk:DropDownButton.DropDownContent>

                    <TextBlock >
                        <Run Text="Empty classification categories" FontWeight="Bold"/>
                        <Run Name="DropDownEmptyLabel" Text="" FontWeight="Normal"/>
                    </TextBlock>
                </xctk:DropDownButton>

                <!--Row 2 Rank By Confidence Checkbox-->
                <RadioButton Name="RankByClassificationConfidenceCheckbox" GroupName="RankByRadioButtons" Content="Sort by classification confidence" Grid.Row="4" Grid.Column="0" Margin="0,10,0,0" 
                          VerticalAlignment="Center" HorizontalAlignment="Left" IsChecked="False" 
                          Checked="RankByConfidence_CheckedChanged" Unchecked="RankByConfidence_CheckedChanged"
                          ToolTip="Sorts the results by confidence.&#10;The confidence value used (detection or classification) depends upon the 'Recognized entity' menu selection."/>
            </Grid>

            <!--Other Recognition-related controls-->
            <StackPanel Grid.Row="0" Grid.Column="2" Grid.RowSpan="3" Name="Recognitions2Panel" Orientation="Vertical" Margin="0,15,0,0" >
                <StackPanel  Orientation="Vertical" >
                    <StackPanel  Orientation="Horizontal" >
                        <TextBlock Name="QueryMatches2" Text="{Binding ElementName=QueryMatches,Path=Text }"  FontWeight="DemiBold" VerticalAlignment="Center" Margin="0,0,0,0"/>
                        <TextBlock Text=" files match your query" VerticalAlignment="Center" Margin="0,0,0,0"/>
                    </StackPanel>
                </StackPanel>
                <CheckBox Name="ShowMissingDetectionsCheckbox" Content="Show only those files&#10;the recognizer did not&#10; process" 
                          IsChecked="False" VerticalAlignment="Center" VerticalContentAlignment="Top" Margin="10,145,0,0" 
                          Checked="ShowMissingDetectionsCheckbox_CheckedChanged" Unchecked="ShowMissingDetectionsCheckbox_CheckedChanged"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
