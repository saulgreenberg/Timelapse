<Window x:Class="Timelapse.Dialog.CustomSelectionWithEpisodes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:controls="clr-namespace:Timelapse.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xceed="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="Select and view a  subset of your files"
        MinHeight="640" MinWidth="705"
		Height="900" Width="783"
		ResizeMode="CanResizeWithGrip"
		ShowInTaskbar="False"
		WindowStartupLocation="CenterOwner"  Loaded="Window_Loaded" >
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ResourceDictionaries/TreeViewHierarchicalDataTemplate.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <DockPanel>
        <controls:StockMessageControl x:Name="Message" DockPanel.Dock="Top" Icon="Question"
                            Title="Select and View a Subset of your Files"
                            What="You may want to view only a subset of your images and videos that fit some criteria of interest to you."
                            Solution="Specify the search terms that describe your criteria.
                                      &#10;1. Each row below reflects your data fields or (if enabled) specific recognition data.
                                      &#10;2. Select one or more rows and adjust its values to reflect your search criteria .
                                      &#10;3. If you have selected multiple terms in the lower area, select how those terms should be combined."
                                      
                            Result="Only those images and videos matching your search criteria will be displayed."
                            Hint="Glob expressions are case sensitive and allow wildcards as follows:&#10;&#x2022; * matches any number of characters and ? matches any single character&#10;&#x2022; [abc] matches one of the indicated characters; [a-z] matches one charecter in the range of indicated characters. "
                            ShowExplanationVisibility="True"/>
        <DockPanel DockPanel.Dock="Bottom">
            <Rectangle Fill="#FF868686" Height="2" DockPanel.Dock="Top"/>
            <Button Name="ResetToAllImagesButton" Content="_Reset to All Images" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="10,0,0,0"  Padding="10" Click="ResetToAllImagesButton_Click" IsEnabled="False"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Name="QueryMatches" HorizontalAlignment="Left"  Margin="10,5,0,5" VerticalAlignment="Center"  FontWeight="DemiBold" FontSize="12"><Run Text="0  "/></TextBlock>
                <TextBlock HorizontalAlignment="Left"  Margin="0,5,0,5" VerticalAlignment="Center"  FontSize="12"><Run Text=" files match your query "/></TextBlock>
                <Button Name="CancelButton" IsCancel="True" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Padding="10" Margin="10,10,10,10" Click="CancelButton_Click">_Cancel</Button>
                <Button Name="OkButton" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Padding="10" Margin="10,10,10,10" Click="OkButton_Click">_Okay</Button>
            </StackPanel>
        </DockPanel>

        <!--Recognitions Area-->
        <Grid DockPanel.Dock="Top" Margin="10,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="0" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" MinHeight="25"/>
            </Grid.RowDefinitions>

            <!--Recognitions Groupbox-->
            <GroupBox Name="RecognitionsGroupBox" Grid.Row="0" Grid.Column="0">
                <GroupBox.Header >
                    <StackPanel Orientation="Horizontal">
                        <CheckBox Name="EnableRecognitionsCheckbox" Margin="0,0,5,0" VerticalAlignment="Center" IsChecked="False" Checked="EnableRecognitions_CheckedChanged" Unchecked="EnableRecognitions_CheckedChanged"/>
                        <TextBlock Text="Enable recognition selections" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left"  />
                    </StackPanel>
                </GroupBox.Header>

                <StackPanel Orientation="Vertical">
                    <!--<controls:RecognitionSelector x:Name="RecognitionSelector"  RecognitionSelectionEvent="RecognitionSelector_OnRecognitionSelectionEvent"/>-->

                    <Grid Visibility="Visible">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" MinHeight="25"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical" 
                                VerticalAlignment="Top"
                                Margin="0,20,5,0">
                            <TextBlock Name="DetectionCategoryLabel" Text="Category" 
                               FontWeight="DemiBold" 
                               HorizontalAlignment="Right" 
                               Margin="0,0,5,0"/>

                            <TextBlock Name="DetectionConfidenceLabel" Text="Confidence" 
                               FontWeight="DemiBold" 
                               HorizontalAlignment="Right" 
                               Margin="0,15,5,0"/>

                            <TextBlock Name="SortByConfidenceLabel" Text="or, sort by" 
                                   FontWeight="DemiBold" 
                                   HorizontalAlignment="Right" 
                                   Margin="0,12,5,0"/>
                        </StackPanel>
                        <!--Detections Groupbox-->
                        <GroupBox Name="DetectionsGroupBox" Grid.Row="0" Grid.Column="1" Header="Detections">
                            <Grid Width="Auto" Height="Auto" DockPanel.Dock="Bottom" Margin="5,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" MinHeight="25" />
                                    <RowDefinition Height="Auto" MinHeight="25" />
                                    <RowDefinition Height="Auto" MinHeight="25" />
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <!--Row 0 Detection Category Menu-->

                                <ComboBox Name="DetectionCategoryComboBox" FontWeight="Normal"   SelectedIndex="1" Grid.Row="0" Grid.Column="0" IsEnabled="False" Margin="0" HorizontalAlignment="Stretch"/>

                                <!--Row 1 Detection Confidence-->

                                <Grid Grid.Row="1" Grid.Column="0" Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="48" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"  />
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <xceed:DoubleUpDown Name="DetectionConfidenceSpinnerLower" 
                                                        Grid.Row="0" Grid.Column="0" 
                                                        Margin="0,0,3,0" 
                                                        FontWeight="Normal" FormatString="F2" 
                                                        Value="0" Increment="0.05"  Maximum="1" Minimum="0" 
                                                        IsEnabled="false" 
                                                        ValueChanged="DetectionConfidenceSpinnerLower_ValueChanged"/>

                                    <xceed:RangeSlider Name="DetectionRangeSlider"  IsEnabled="True" HorizontalAlignment="Stretch" VerticalAlignment="Center" Grid.Row="0" Grid.Column="1" 
                                                   HigherValue="1" LowerValue=".8" Maximum="1" Minimum="0" Step="0.01"
                                                   HigherValueChanged="DetectionRangeSlider_HigherValueChanged" LowerValueChanged="DetectionRangeSlider_LowerValueChanged"  
                                                   HigherRangeBackground="Transparent"
                                                   LowerRangeBackground="Transparent"
                                                   RangeBackground="Gold"
                                                   TickFrequency=".2"
                                                   TickPlacement="BottomRight"/>

                                    <xceed:DoubleUpDown Name="DetectionConfidenceSpinnerHigher"  
                                                    Grid.Row="0" Grid.Column="2" 
                                                    Margin="3,0,0,0"
                                                    FontWeight="Normal" FormatString="F2" 
                                                    Value="1" Increment="0.05" Maximum="1" Minimum="0" 
                                                    IsEnabled="false" 
                                                    ValueChanged="DetectionConfidenceSpinnerHigher_ValueChanged"/>
                                </Grid>

                                <!--Row 2 Rank By Confidence Checkbox-->
                                <RadioButton Name="RankByDetectionConfidenceCheckbox" GroupName="RankByConf" Content="by detection confidence" Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" 
                                      VerticalAlignment="Center" HorizontalAlignment="Left" IsChecked="False" 
                                      Checked="RankByConfidence_CheckedChanged" Unchecked="RankByConfidence_CheckedChanged"
                                      ToolTip="Sorts the results by confidence.&#10;The confidence value used (detection or classification) depends upon the 'Recognized entity' menu selection."/>
                            </Grid>
                        </GroupBox>

                        <!-- Classifications GroupBox-->
                        <GroupBox Name="ClassificationsGroupBox" Grid.Row="0" Grid.Column="2" Header="Classifications">
                            <Grid Width="Auto" Height="Auto" DockPanel.Dock="Bottom" Margin="5,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" MinHeight="25" />
                                    <RowDefinition Height="Auto" MinHeight="25" />
                                    <RowDefinition Height="Auto" MinHeight="25" />
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <!--Row 0 Classification Category Menu-->
                                <TextBlock Name="ClassificationCategoryLabel" Text="Category" FontWeight="DemiBold" 
                                    Grid.Row="0" Grid.Column="0" 
                                    VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="1,0,5,5"/>
                                <ComboBox Name="ClassificationCategoryComboBox" FontWeight="Normal"   SelectedIndex="1" Grid.Row="0" Grid.Column="0" IsEnabled="True" Margin="0" HorizontalAlignment="Stretch"/>
                                <!--Row 1 Classification Confidence-->

                                <Grid Grid.Row="1" Grid.Column="0" Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="25"  />
                                    </Grid.RowDefinitions>

                                    <xceed:DoubleUpDown Name="ClassificationConfidenceSpinnerLower" 
                                         Grid.Row="0" Grid.Column="0" 
                                         Margin="0,0,3,0" 
                                         FontWeight="Normal" FormatString="F2" 
                                         Value="0" Increment="0.05"  Maximum="1" Minimum="0" 
                                         IsEnabled="false" 
                                         ValueChanged="ClassificationConfidenceSpinnerLower_ValueChanged"/>

                                    <Slider Name="ClassificationRangeSlider"  IsEnabled="True" VerticalAlignment="Top"
                                        Grid.Row="0" Grid.Column="1" 
                                        Maximum="1" SmallChange="0.01" TickFrequency="0.2" TickPlacement="BottomRight" 
                                        ValueChanged="ClassificationSlider_ValueChanged"  Margin="0,0,0,0"  
                                    />

                                    <!--<xceed:DoubleUpDown Name="ClassificationConfidenceSpinnerHigher"  
                                         Grid.Row="0" Grid.Column="3" 
                                         Margin="2,0,0,112"
                                         FontWeight="Normal" FormatString="F2" 
                                         Value="1" Increment="0.05" Maximum="1" Minimum="0" 
                                         IsEnabled="true" 
                                         ValueChanged="ClassificationRangeSlider_HigherValueChanged"/>-->
                                </Grid>

                                <!--Row 2 Rank By Confidence Checkbox-->
                                <RadioButton Name="RankByClassificationConfidenceCheckbox" GroupName="RankByConf" Content="by classification confidence" Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" 
                                             VerticalAlignment="Center" HorizontalAlignment="Left" IsChecked="False" 
                                             Checked="RankByConfidence_CheckedChanged" Unchecked="RankByConfidence_CheckedChanged"
                                             ToolTip="Sorts the results by confidence.&#10;The confidence value used (detection or classification) depends upon the 'Recognized entity' menu selection."/>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </StackPanel>
            </GroupBox>


            <!--Other Recognition-related controls-->
            <StackPanel Grid.Row="0" Grid.Column="1" Name="Recognitions2Panel" Orientation="Vertical" Margin="0,0,0,0" Visibility="Collapsed">
                <Button Name="ButtonRecognitionExplorer" Content="Recognitions Explorer" ToolTip="The Recognitions Explorer displays the number of files matching each recognition"
                        Margin="10,10,10,0" Height="30"  HorizontalAlignment="Stretch" Visibility="Visible"
                        Click="ButtonRecognitionExplorer_OnClick"/>
                <CheckBox Name="ShowMissingDetectionsCheckbox" Content="Show only those files&#10;the recognizer did not&#10; process" IsChecked="False" VerticalAlignment="Center" VerticalContentAlignment="Top" Margin="10,10,0,0" Checked="ShowMissingDetectionsCheckbox_CheckedChanged" Unchecked="ShowMissingDetectionsCheckbox_CheckedChanged"/>

                <StackPanel  Orientation="Vertical" Margin="10,18,0,0">
                    <StackPanel  Orientation="Horizontal">
                        <TextBlock Name="QueryMatches2" Text="{Binding ElementName=QueryMatches,Path=Text }"  FontWeight="DemiBold" VerticalAlignment="Center" Margin="0,0,0,0"/>
                        <TextBlock Text=" files match your query" VerticalAlignment="Center" Margin="0,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>


        <!--Row 4 Option to show episode info -->
        <StackPanel Name="ShowEpisodeOptionsPanel" Orientation="Horizontal" Margin="30,5,0,0"  DockPanel.Dock="Top" >
            <CheckBox Name="CheckboxShowAllEpisodeImages" 
                      VerticalContentAlignment="Center" FontWeight="DemiBold"
                      Content="Include all files in an episode when at least one file matches" IsChecked="False"
                      Checked="CheckboxShowAllEpisodeImages_CheckedChanged" Unchecked="CheckboxShowAllEpisodeImages_CheckedChanged"
                      ToolTip="Show all files in an episode where at least one file in that episode matches the search criteria"/>
        </StackPanel>

        <!--Selection Panel-->
        <GroupBox Name="SelectionGroupBox" Header="Select images and videos that match these terms " FontWeight="Bold" FontStyle="Italic" Height="Auto" DockPanel.Dock="Bottom" Margin="10,15,5,0" Padding="0,10,0,00">
            <DockPanel>
                <ScrollViewer FontStyle="Normal">
                    <Grid Name="SearchTerms" Width="Auto" Height="Auto" DockPanel.Dock="Bottom">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" MinWidth="305"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Padding ="10,0,5,0" FontWeight="Bold" Text="Select" Grid.Row="0" Grid.Column="0"/>
                        <TextBlock Padding ="5,0,5,0" FontWeight="Bold" Text="Label" Grid.Row="0" Grid.Column="1"/>
                        <TextBlock Padding ="5,0,5,0" FontWeight="Bold" Text="Expression" Grid.Row="0" Grid.Column="2"/>
                        <TextBlock Padding ="5,0,5,0" FontWeight="Bold" Text="Value" Grid.Row="0" Grid.Column="3"/>
                        <TextBlock Padding ="5,0,5,0" FontWeight="Bold" Text="How multiple terms are combined" Grid.Row="0" Grid.Column="4"/>
                    </Grid>
                </ScrollViewer>
            </DockPanel>
        </GroupBox>

    </DockPanel>
</Window>
