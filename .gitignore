# Keep: Solution, as convenient for rebuilding everything
!*.sln

# Keep: Dependent .exes (they could also downloaded from their official sites)
*ffmpeg.exe
*exiftool(-k).exe

# Omit: Dependency
/Dependencies/*

# Keep: Dependent dll's - their were modified somewhat to work with Timelapse 
# If you want the source, ask me
!/Dependencies/*.dll
!/Dependencies/*.exe

# Omit: User-specific files 
*.suo
*.user

# Omit: Visual Studio generated files and other auxilliary files not needed for rebuilding the project 
.vs/
*.vsp
*.vspx
*.tmp
debug.log
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
**/StyleCop.Cache

# Omit: Build results 
bin/
packages/
obj/

# Omit: NuGet Packages
**/packages/*

# Keep: NuGet build/, which is used as an MSBuild target.
# and any custom dlls that aren't from NuGet
!**/packages/build/

# Omit: Folders and files that may be created by running Timelapse
Backups/


