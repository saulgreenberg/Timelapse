<UserControl x:Class="Timelapse.Controls.TreeViewSpeciesTaxonomy"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10,0,0,2" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Expand to:" FontWeight="DemiBold" Padding ="0,0,4,0"  Margin="0,0,6,0"/>

            <RadioButton Grid.Column="1"   x:Name="RadioExpandClass" Content="Class" Margin="0,1,6,0"
                         Checked="RadioExpandClass_Checked" IsChecked="True" GroupName="Group1"/>
            <RadioButton Grid.Column="2"  x:Name="RadioExpandOrder" Content="Order" Margin="0,1,6,0"
                         Checked="RadioExpandOrder_Checked" IsChecked="False" GroupName="Group1"/>
            <RadioButton Grid.Column="3"  x:Name="RadioExpandFamily" Content="Family"
                         Checked="RadioExpandFamily_Checked" IsChecked="False" Margin="0,1,6,0" GroupName="Group1"/>
            <RadioButton Grid.Column="4"  x:Name="RadioExpandGenus" Content="Genus" 
                         Checked="RadioExpandGenus_Checked" IsChecked="False" Margin="0,1,6,0" GroupName="Group1"/>
            <RadioButton Grid.Column="5"  x:Name="RadioExpandSpecies" Content="Species" Margin="0,1,0,0"
                         Checked="RadioExpandSpecies_Checked" GroupName="Group1"/>

        </Grid>

        <TreeView x:Name="SpecieNetTreeView" Grid.Row="1"
                  SelectedItemChanged="SpecieNetTreeView_SelectedItemChanged"
                  PreviewMouseLeftButtonDown="SpecieNetTreeView_PreviewMouseLeftButtonDown"
                  PreviewMouseLeftButtonUp="SpecieNetTreeView_PreviewMouseLeftButtonUp"
                  MouseLeave="SpecieNetTreeView_MouseLeave" />

        <!-- Popup: visible while the mouse button is held over a node -->
        <Popup Grid.Row="0" x:Name="NodeInfoPopup" Placement="MousePoint" StaysOpen="True"
               AllowsTransparency="True" HorizontalOffset="16">
            <Border x:Name="NodeInfoPopupBorder" Background="LightYellow" BorderBrush="Gray" BorderThickness="1"
                    CornerRadius="3" Padding="6,4">
                <TextBlock x:Name="PopupTextBlock" FontFamily="Consolas" FontSize="11" />
            </Border>
        </Popup>

        <!-- Debug output: shows key/common-name for the selected node and its terminal descendants -->
        <TextBox x:Name="DebugTextBox" Grid.Row="2" Visibility="Collapsed"
                 IsReadOnly="True" Height="80" Margin="0,4,0,0"
                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="11" />
    </Grid>
</UserControl>
