<Window  x:Class="Timelapse.Dialog.ClassificationByTaxonomyDialog"
                                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                                xmlns:toolkit="http://timelapsewpf.toolkit/xaml"
                                xmlns:controls="clr-namespace:Timelapse.Controls"
                                mc:Ignorable="d"
                                Title="Select by Taxonomy" Height="500" Width="500" MinWidth="400" MinHeight="400"
                WindowStartupLocation="Manual" Loaded="ClassificationByTaxonomyDialog_OnLoaded">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header/Instructions -->
        <toolkit:FormattedMessageContent x:Name="DialogMessage" Grid.Row="0"
                        Icon="{x:Static toolkit:DialogIconType.Question}"
                        DialogTitle="Select by Taxonomy"
                        What="A taxonomy of possible species classifications in your images.[br]Use it to select all species under a taxonomic entry."
                        Hint="Click:[li]arrows to expand or collapse an entry[li]text labels to select that taxonomic level"
                        ShowExplanationVisibility="True" />

        <!-- SpecieNet taxonomy tree -->
        <controls:TreeViewSpeciesTaxonomy x:Name="TreeViewSpeciesTaxonomy" Grid.Row="1" />

        <!-- Dismiss button -->
        <Button Grid.Row="2" Content="Okay" Width="75" HorizontalAlignment="Right"
                Margin="0,4,0,0" Padding="10" Click="BtnOkay_Click" />

    </Grid>
</Window>
